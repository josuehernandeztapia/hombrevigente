    def redact_for_preview(text = None):
        if not text:
            return text
        import re
        text = re.sub('\\+?\\d[\\d\\s-]{8,}\\d', '[PHONE]', text)
        text = re.sub('[\\w\\.-]+@[\\w\\.-]+\\.\\w+', '[EMAIL]', text)
        return text[:200] + '…' if len(text) > 200 else text

