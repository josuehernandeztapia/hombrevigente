def normalize_model_id(model = None):
    '''
    Patrón exacto de la Guía Agéntica Estándar para que los costos no den 0 silenciosamente.
    Quita sufijos de release (gpt-4o-mini-2024-07-18 → gpt-4o-mini).
    '''
    if not model:
        return model
    import re
    stripped = re.sub('-\\d{4}-\\d{2}-\\d{2}$', '', model)
    if stripped != model:
        return stripped
    stripped2 = None.sub('-\\d{8}$', '', model)
    if stripped2 != model:
        return stripped2

