# =============================================================================
# HOMBRE VIGENTE - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# INSTRUCCIONES:
# 1. Copiar este archivo como .env: cp .env.example .env
# 2. Rellenar con tus API keys reales
# 3. NUNCA commitear .env con secrets reales
# =============================================================================

# -----------------------------------------------------------------------------
# OPENAI API (REQUERIDO para RAG)
# -----------------------------------------------------------------------------
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# VECTOR DATABASE (Elegir UNA opción)
# -----------------------------------------------------------------------------
# Opción 1: QDRANT CLOUD (Recomendado)
# Free tier: https://cloud.qdrant.io/
# QDRANT_URL=https://xxxxx-xxxxx.qdrant.io
# QDRANT_API_KEY=your-api-key-here

# Opción 2: PINECONE
# Free tier: https://www.pinecone.io/
PINECONE_API_KEY=pcsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=hombre-vigente-kb

# -----------------------------------------------------------------------------
# TWILIO (OPCIONAL - Solo para WhatsApp)
# -----------------------------------------------------------------------------
# Obtener en: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_NUMBER=+14155238886

# -----------------------------------------------------------------------------
# WHISPER API (OPCIONAL - Solo para transcripción voz)
# -----------------------------------------------------------------------------
WHISPER_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./vigente_v3.db

# -----------------------------------------------------------------------------
# BACKEND CONFIGURATION
# -----------------------------------------------------------------------------
DEBUG=True
ENVIRONMENT=development
SECRET_KEY=change-this-to-random-secret-key
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# RAG CONFIGURATION
# -----------------------------------------------------------------------------
KNOWLEDGE_BASE_PATH=./knowledge_base
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
SIMILARITY_THRESHOLD=0.75
TOP_K_RESULTS=5
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# Confianza retrieval (patrón CMU PARTES_MERCADO_* / PR #438)
HV_COSINE_HIGH=0.70
HV_COSINE_MIN=0.55
HV_SCORE_COSINE_WEIGHT=0.7
HV_SCORE_META_WEIGHT=0.3

# Observabilidad RAG
HV_DECISION_LOG_PATH=./data/decision_log.jsonl
HV_DECISION_LOG_ENABLED=true
HV_ADMIN_PIN=change-me-in-production

# Retrieval backend: json (default) | pgvector (Neon)
HV_RETRIEVAL_BACKEND=json
# Fly: volumen persistente para índice + decision log
# HV_EMBEDDINGS_INDEX=/data/embeddings_local.json
# Neon Postgres (pgvector) — override sqlite para RAG
# HV_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/hv?sslmode=require

# -----------------------------------------------------------------------------
# AGENTS CONFIGURATION
# -----------------------------------------------------------------------------
DIAGNOSTICO_ENABLE_THERMAL=True
DIAGNOSTICO_ENABLE_RGB=True
PERSONA_DEFAULT_MODELO=arquetipos_modelo_financiero.json
OPTI_ENABLE_BNPL=True
OPTI_BNPL_THRESHOLD=2500
CHAT_ENABLE_RAG=True
CHAT_ENABLE_CONTEXT_ENRICHMENT=True

# -----------------------------------------------------------------------------
# BUSINESS MODEL
# -----------------------------------------------------------------------------
MEMBERSHIP_ACCESS_PRICE=1400
MEMBERSHIP_ACCESS_DISCOUNT=0.15
MEMBERSHIP_ELITE_PRICE=3800
MEMBERSHIP_ELITE_DISCOUNT=0.20
BNPL_MIN_THRESHOLD=2500
BNPL_REVENUE_UPLIFT=1.25
REVENUE_SHARE_PREMIUM=0.35
REVENUE_SHARE_SURGERY=0.50

# -----------------------------------------------------------------------------
# DEMO MODE
# -----------------------------------------------------------------------------
DEMO_MODE=True
DEMO_SKIP_PAYMENT_PROCESSING=True
DEMO_SKIP_WHATSAPP_SEND=True
ENABLE_SYNTHETIC_DATA=True
SYNTHETIC_CLIENTS_COUNT=100

# =============================================================================
# FIN DEL TEMPLATE
# =============================================================================
